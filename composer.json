{
  "name": "kingsleyinfo/woocommerce-conflict-doctor",
  "description": "Automated plugin/theme conflict testing for WooCommerce merchants.",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6",
    "brain/monkey": "^2.6"
  },
  "autoload": {},
  "autoload-dev": {
    "psr-4": {
      "WCD\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml"
  }
}
